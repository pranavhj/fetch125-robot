<launch>
  <param name="robot/type" value="fetch" />
  <param name="robot/name" textfile="/etc/hostname" />

  <!-- Calibration -->
  <param name="calibration_date" value="uncalibrated" />
  <param name="base_controller/track_width" value="0.37476" />

  <!-- Odometry -->
  <param name="base_controller/publish_tf" value="false" />
  <include file="$(find fetch_bringup)/launch/include/graft.launch.xml" />

  <!-- URDF -->
  <param name="robot_description" textfile="$(find fetch_description)/robots/fetch.urdf" />

  <!-- Drivers: base only, no arm/head/torso -->
  <node name="robot_driver" pkg="fetch_drivers" type="robot_driver" output="log">
    <param name="firmware_tar_gz" value="$(find fetch_drivers)/firmware.tar.gz" />
    <param name="has_base" value="true" />
    <param name="has_torso" value="false" />
    <param name="has_head" value="false" />
    <param name="has_arm" value="false" />
    <param name="parampath" value="/home/fetch/base_driver_params_false.json" />
  </node>

  <!-- Controllers -->
  <rosparam file="/home/fetch/base_only_controllers.yaml" command="load" />

  <!-- Joint State -> TF -->
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" />

  <!-- RealSense D435 depth camera -->
  <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <arg name="align_depth" value="true" />
  </include>

  <!-- Laser -->
  <include file="$(find fetch_bringup)/launch/include/laser.launch.xml" />

  <!-- Software Runstop -->
  <include file="$(find fetch_bringup)/launch/include/runstop.launch.xml">
    <arg name="flags" value="-b" />
  </include>

  <!-- cmd_vel mux: routes /cmd_vel and /teleop/cmd_vel to base_controller -->
  <node name="cmd_vel_mux" pkg="topic_tools" type="mux" args="base_controller/command /cmd_vel /teleop/cmd_vel">
    <remap from="mux" to="cmd_vel_mux" />
    <param name="initial_topic" value="/cmd_vel" />
  </node>

  <!-- Auto Dock / Undock -->
  <node name="auto_dock" pkg="fetch_open_auto_dock" type="auto_dock" output="log" />

  <!-- Diagnostics Aggregator -->
  <include file="$(find fetch_bringup)/launch/include/aggregator.launch.xml" />

</launch>
